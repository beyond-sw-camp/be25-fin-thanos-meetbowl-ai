RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://meetbowl:local-rabbitmq-password@localhost:5672/
RABBITMQ_EXCHANGE=meetbowl.topic
RABBITMQ_MINUTES_GENERATE_QUEUE=ai.minutes.generate
RABBITMQ_MINUTES_REGENERATE_QUEUE=ai.minutes.regenerate
RABBITMQ_MINUTES_GENERATED_ROUTING_KEY=minutes.generated
RABBITMQ_MAX_RETRIES=3
GEMINI_API_KEY=
MINUTES_MODEL_PROFILE=minutes-summary
MINUTES_SUMMARY_PROVIDER=gemini
MINUTES_SUMMARY_MODEL=gemini-2.5-flash
MINUTES_SUMMARY_TEMPERATURE=0.2
CHATBOT_MODEL_PROFILE=chatbot
CHATBOT_PROVIDER=gemini
CHATBOT_MODEL=gemini-2.5-flash
CHATBOT_TEMPERATURE=0.2
MEETING_FEEDBACK_MODEL_PROFILE=meeting-feedback
MEETING_FEEDBACK_PROVIDER=gemini
MEETING_FEEDBACK_MODEL=gemini-2.5-flash
MEETING_FEEDBACK_TEMPERATURE=0.2
DOCUMENT_EMBEDDING_MODEL_PROFILE=document-embedding
DOCUMENT_EMBEDDING_PROVIDER=gemini
DOCUMENT_EMBEDDING_MODEL=gemini-embedding-001
QUERY_EMBEDDING_MODEL_PROFILE=query-embedding
QUERY_EMBEDDING_PROVIDER=gemini
QUERY_EMBEDDING_MODEL=gemini-embedding-001
MINUTES_PROMPT_VERSION=minutes-v1
